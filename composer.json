{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "art35rennes/laravel-daisy-kit",
    "type": "library",
    "description": "Reusable Laravel Blade UI kit built with DaisyUI and Tailwind CSS.",
    "keywords": [
        "laravel",
        "blade",
        "components",
        "daisyui",
        "tailwindcss"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "blade-ui-kit/blade-icons": "^1.8",
        "davidhsianturi/blade-bootstrap-icons": "^2.1",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/routing": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/view": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/boost": "^2.4",
        "laravel/framework": "^11.0|^12.0|^13.0",
        "laravel/pint": "^1.25",
        "pestphp/pest": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "Art35rennes\\DaisyKit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Art35rennes\\DaisyKit\\DaisyKitServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "pest",
        "lint": "pint --parallel"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
